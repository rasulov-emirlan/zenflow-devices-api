PORT=8080
DATABASE_URL=postgres://zenflow:zenflow@localhost:5432/zenflow?sslmode=disable
LOG_LEVEL=info

# deployment environment: dev | staging | prod
APP_ENV=dev
# migration policy on boot: auto | manual | off
# default is auto in dev/staging and off in prod (auto in prod is rejected)
MIGRATE_MODE=auto
# load seed data (templates) on boot; dev-only, rejected in prod
SEED_ON_BOOT=false

# comma-separated user:bcrypt-hash pairs
# generate a hash with: htpasswd -bnBC 10 "" secret | tr -d ':\n'
BASIC_AUTH_USERS=alice:$2a$10$Y10WC4uCFi2qC5f/gts5s.5qYGjkRJM5It.MKhZvAevUnto6fyMgi

# ---- observability ----
# admin listener for Prometheus /metrics and /healthz (kept off the public API port)
METRICS_ADDR=:9090
# OTLP gRPC endpoint for traces (host:port, no scheme); in-cluster default
OTLP_ENDPOINT=otel-collector:4317
# enable OTEL tracing export; off by default so the app runs without a collector
TRACING_ENABLED=false
# OTEL service.name resource attribute
OTEL_SERVICE_NAME=zenflow-devices-api
